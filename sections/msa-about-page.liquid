{%- liquid
  assign section_st = section.settings
  assign section_width = section_st.section_width
-%}

{%- capture style -%}
  --section-pt: {{ section_st.padding_top }}px;
  --section-pb: {{ section_st.padding_bottom }}px;
{%- endcapture -%}

<div
  class="section msa-about{% if section_st.padding_top < 30 %} pt-min{% endif %}{% if section_st.padding_bottom < 30 %} pb-min{% endif %}"
  style="{{ style | strip | strip_newlines }}"
>
  <div class="{{ section_width }}">
    {%- assign cards_open = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'card' -%}
        {%- unless cards_open -%}
          <div class="msa-about__cards grid grid-cols gap" style="--col-desktop: {{ section_st.cards_per_row | default: 4 }}; --col-tablet: 2; --col-number: 1;">
          {%- assign cards_open = true -%}
        {%- endunless -%}
        <div class="msa-about__card" {{ block.shopify_attributes }}>
          {%- if block.settings.title != blank -%}
            <h3 class="msa-about__card-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="msa-about__card-text rte">{{ block.settings.text }}</div>
          {%- endif -%}
        </div>
      {%- else -%}
        {%- if cards_open -%}
          </div>
          {%- assign cards_open = false -%}
        {%- endif -%}
        {%- case block.type -%}
        {%- when 'hero' -%}
          <div class="msa-about__hero" {{ block.shopify_attributes }}>
            <div class="msa-about__hero-content">
              {%- if block.settings.subheading != blank -%}
                <p class="msa-about__eyebrow">{{ block.settings.subheading }}</p>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h2 class="msa-about__heading">{{ block.settings.heading }}</h2>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="msa-about__text rte">{{ block.settings.text }}</div>
              {%- endif -%}
            </div>
            {%- if block.settings.image_url != blank -%}
              <div class="msa-about__hero-media">
                <img
                  src="{{ block.settings.image_url }}"
                  alt="{{ block.settings.image_alt | escape }}"
                  loading="lazy"
                  width="960"
                  height="640"
                >
              </div>
            {%- endif -%}
          </div>

        {%- when 'image_text' -%}
          <div class="msa-about__split{% if block.settings.image_position == 'right' %} msa-about__split--reverse{% endif %}" {{ block.shopify_attributes }}>
            {%- if block.settings.image_url != blank -%}
              <div class="msa-about__split-media">
                <img
                  src="{{ block.settings.image_url }}"
                  alt="{{ block.settings.image_alt | escape }}"
                  loading="lazy"
                  width="720"
                  height="540"
                >
              </div>
            {%- endif -%}
            <div class="msa-about__split-content">
              {%- if block.settings.title != blank -%}
                <h3 class="msa-about__title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.body != blank -%}
                <div class="msa-about__text rte">{{ block.settings.body }}</div>
              {%- endif -%}
            </div>
          </div>

        {%- when 'content' -%}
          <div class="msa-about__block" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="msa-about__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <div class="msa-about__text rte">{{ block.settings.body }}</div>
            {%- endif -%}
          </div>

        {%- when 'chips' -%}
          <div class="msa-about__block msa-about__block--wide" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="msa-about__title msa-about__title--center">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.intro != blank -%}
              <div class="msa-about__text msa-about__text--center rte">{{ block.settings.intro }}</div>
            {%- endif -%}
            {%- if block.settings.items != blank -%}
              <ul class="msa-about__chips list-unstyled">
                {%- assign chip_items = block.settings.items | newline_to_br | split: '<br />' -%}
                {%- for item in chip_items -%}
                  {%- assign item_clean = item | strip -%}
                  {%- if item_clean != blank -%}
                    <li class="msa-about__chip">{{ item_clean }}</li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endif -%}
            {%- if block.settings.note != blank -%}
              <p class="msa-about__note">{{ block.settings.note }}</p>
            {%- endif -%}
          </div>

        {%- when 'cards_heading' -%}
          <div class="msa-about__block msa-about__block--wide msa-about__cards-heading" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="msa-about__title msa-about__title--center">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.subtitle != blank -%}
              <div class="msa-about__text msa-about__text--center rte">{{ block.settings.subtitle }}</div>
            {%- endif -%}
          </div>

        {%- when 'highlight' -%}
          <div class="msa-about__highlight" {{ block.shopify_attributes }}>
            {%- if block.settings.subheading != blank -%}
              <p class="msa-about__eyebrow msa-about__eyebrow--light">{{ block.settings.subheading }}</p>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="msa-about__highlight-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <div class="msa-about__highlight-text rte">{{ block.settings.body }}</div>
            {%- endif -%}
          </div>

        {%- when 'checklist' -%}
          <div class="msa-about__block msa-about__block--wide" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="msa-about__title msa-about__title--center">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.items != blank -%}
              <ul class="msa-about__checklist list-unstyled">
                {%- assign check_items = block.settings.items | newline_to_br | split: '<br />' -%}
                {%- for item in check_items -%}
                  {%- assign item_clean = item | strip -%}
                  {%- if item_clean != blank -%}
                    <li class="msa-about__check-item">
                      <svg class="msa-about__check-icon" width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <circle cx="10" cy="10" r="10" fill="#e85d04"/>
                        <path d="M6 10.4l2.6 2.6L14 7.6" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                      </svg>
                      <span>{{ item_clean }}</span>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

        {%- when 'closing' -%}
          <div class="msa-about__closing" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="msa-about__title msa-about__title--center">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <div class="msa-about__text msa-about__text--center rte">{{ block.settings.body }}</div>
            {%- endif -%}
          </div>
        {%- endcase -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if cards_open -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .msa-about {
    padding-top: var(--section-pt, 40px);
    padding-bottom: var(--section-pb, 60px);
    color: #1a1a1a;
  }

  .msa-about__eyebrow {
    color: #e85d04;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 12px;
  }

  .msa-about__eyebrow--light {
    color: #ffb98a;
  }

  .msa-about__heading {
    font-size: clamp(2.6rem, 4vw, 4rem);
    font-weight: 800;
    color: #1a3a6b;
    margin: 0 0 20px;
    line-height: 1.12;
  }

  .msa-about__title {
    font-size: clamp(2rem, 3vw, 2.6rem);
    font-weight: 700;
    color: #1a3a6b;
    margin: 0 0 16px;
  }

  .msa-about__title--center {
    text-align: center;
  }

  .msa-about__text {
    font-size: 1.5rem;
    line-height: 1.75;
    color: #333;
  }

  .msa-about__text--center {
    text-align: center;
    max-width: 780px;
    margin-left: auto;
    margin-right: auto;
  }

  .msa-about__text p {
    margin-bottom: 1.2em;
  }

  .msa-about__block {
    max-width: 900px;
    margin: 0 auto 48px;
  }

  .msa-about__block--wide {
    max-width: 1080px;
  }

  /* Hero */
  .msa-about__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: 4rem;
    align-items: center;
    margin: 0 auto 56px;
    max-width: 1160px;
  }

  .msa-about__hero-media img,
  .msa-about__split-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 6px;
  }

  .msa-about__hero-media {
    box-shadow: 12px 12px 0 0 #f2e8df;
    border-radius: 6px;
  }

  /* Split image/text rows */
  .msa-about__split {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 4rem;
    align-items: center;
    margin: 0 auto 56px;
    max-width: 1160px;
  }

  .msa-about__split--reverse .msa-about__split-media {
    order: 2;
  }

  .msa-about__split--reverse .msa-about__split-content {
    order: 1;
  }

  .msa-about__split-media {
    align-self: stretch;
    border-radius: 6px;
    overflow: hidden;
  }

  /* Category chips */
  .msa-about__chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin: 2.4rem 0 0;
    padding: 0;
  }

  .msa-about__chip {
    background: #f8f9fb;
    border: 1px solid #dfe5ee;
    color: #1a3a6b;
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 1rem 1.8rem;
    border-radius: 999px;
  }

  .msa-about__note {
    text-align: center;
    color: #666;
    font-size: 1.35rem;
    margin: 2.4rem auto 0;
    max-width: 640px;
  }

  /* Cards */
  .msa-about__cards-heading {
    margin-bottom: 28px;
  }

  .msa-about__cards {
    max-width: 1160px;
    margin: 0 auto 56px;
  }

  .msa-about__card {
    background: #f8f9fb;
    border: 1px solid #e8ecf2;
    border-top: 3px solid #e85d04;
    border-radius: 6px;
    padding: 28px 24px;
    height: 100%;
  }

  .msa-about__card-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: #1a3a6b;
    margin: 0 0 10px;
  }

  .msa-about__card-text {
    font-size: 1.4rem;
    line-height: 1.65;
    color: #444;
  }

  /* Highlight band */
  .msa-about__highlight {
    background: #1a3a6b;
    color: #fff;
    border-radius: 6px;
    padding: clamp(3rem, 5vw, 5.6rem);
    text-align: center;
    margin: 0 auto 56px;
    max-width: 1160px;
  }

  .msa-about__highlight-title {
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 800;
    color: #fff;
    margin: 0 0 16px;
  }

  .msa-about__highlight-text {
    font-size: 1.5rem;
    line-height: 1.75;
    color: #d9e2f2;
    max-width: 820px;
    margin: 0 auto;
  }

  .msa-about__highlight-text p {
    margin-bottom: 1.2em;
  }

  .msa-about__highlight-text p:last-child {
    margin-bottom: 0;
  }

  /* Checklist */
  .msa-about__checklist {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.4rem 3rem;
    margin: 2.8rem auto 0;
    padding: 0;
    max-width: 860px;
  }

  .msa-about__check-item {
    display: flex;
    align-items: flex-start;
    gap: 1.2rem;
    font-size: 1.45rem;
    line-height: 1.55;
    color: #333;
  }

  .msa-about__check-icon {
    flex: 0 0 auto;
    margin-top: 0.3em;
  }

  /* Closing */
  .msa-about__closing {
    border-top: 1px solid #e8ecf2;
    padding-top: 4rem;
    margin: 0 auto;
    max-width: 900px;
  }

  @media (max-width: 1024px) {
    .msa-about__hero,
    .msa-about__split {
      gap: 2.8rem;
    }
  }

  @media (max-width: 767px) {
    .msa-about__hero,
    .msa-about__split {
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-bottom: 40px;
    }

    .msa-about__hero-media {
      order: -1;
      box-shadow: none;
    }

    .msa-about__split--reverse .msa-about__split-media,
    .msa-about__split-media {
      order: -1;
    }

    .msa-about__checklist {
      grid-template-columns: 1fr;
    }

    .msa-about__block {
      margin-bottom: 36px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MSA about page",
  "tag": "section",
  "class": "section-msa-about",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:sections.all.section_width.label",
      "default": "fluid_container",
      "options": [
        { "value": "container", "label": "t:sections.all.section_width.container.label" },
        { "value": "fluid_container", "label": "t:sections.all.section_width.fluid_container.label" },
        { "value": "stretch_width", "label": "t:sections.all.section_width.stretch_width.label" }
      ]
    },
    {
      "type": "range",
      "id": "cards_per_row",
      "label": "Cards per row (desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.section_padding.top.label",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.section_padding.bottom.label",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "hero",
      "name": "Hero intro",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "subheading", "label": "Eyebrow" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "richtext", "id": "text", "label": "Text" },
        { "type": "text", "id": "image_url", "label": "Image URL" },
        { "type": "text", "id": "image_alt", "label": "Image alt text" }
      ]
    },
    {
      "type": "image_text",
      "name": "Image with text",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "body", "label": "Body" },
        { "type": "text", "id": "image_url", "label": "Image URL" },
        { "type": "text", "id": "image_alt", "label": "Image alt text" },
        {
          "type": "select",
          "id": "image_position",
          "label": "Image position",
          "default": "left",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ]
        }
      ]
    },
    {
      "type": "content",
      "name": "Content",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "body", "label": "Body" }
      ]
    },
    {
      "type": "chips",
      "name": "Category chips",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "intro", "label": "Intro text" },
        { "type": "textarea", "id": "items", "label": "Items", "info": "One item per line" },
        { "type": "text", "id": "note", "label": "Note below chips" }
      ]
    },
    {
      "type": "cards_heading",
      "name": "Cards section heading",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "subtitle", "label": "Subtitle" }
      ]
    },
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "text", "label": "Text" }
      ]
    },
    {
      "type": "highlight",
      "name": "Highlight band",
      "settings": [
        { "type": "text", "id": "subheading", "label": "Eyebrow" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "body", "label": "Body" }
      ]
    },
    {
      "type": "checklist",
      "name": "Checklist",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "items", "label": "Items", "info": "One item per line" }
      ]
    },
    {
      "type": "closing",
      "name": "Closing",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "body", "label": "Body" }
      ]
    }
  ],
  "presets": [
    {
      "name": "MSA about page"
    }
  ]
}
{% endschema %}
