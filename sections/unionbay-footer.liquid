{{ 'collapsible.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign section_st = section.settings
  assign container = section_st.section_width
  assign color_scheme = section_st.color_scheme
-%}

{%- capture style -%}
--section-pt: {{ section_st.padding_top }};
--section-pb: {{ section_st.padding_bottom }};
{%- endcapture -%}

<footer
  class="unionbay-footer footer color-{{ color_scheme }} gradient"
  style="{{ style | strip | strip_newlines }}"
  role="contentinfo"
>
  {%- if section_st.enable_back_top -%}
    <back-to-top class="back-to-top transition invisible pointer w-50 h-50 inline-flex content-center shadow bg-white fixed bottom-30 right-30 z-5 rounded-50 overflow-hidden">
      <span class="absolute left-0 bottom-0 w-full bg-dark height-scroll"></span>
      <svg width="8" height="10" fill="none" class="color-white mix-blend">
        <path fill="currentColor" d="M7.797 4.203h.016A.636.636 0 0 1 8 4.672a.67.67 0 0 1-.188.469.69.69 0 0 1-.484.187.67.67 0 0 1-.469-.187L4 2.28l-2.86 2.86a.69.69 0 0 1-.484.187.617.617 0 0 1-.453-.187A.644.644 0 0 1 0 4.67c0-.187.068-.343.203-.468L3.531.86A.636.636 0 0 1 4 .672c.188 0 .344.062.469.187l3.328 3.344Zm0 4.656h.016A.69.69 0 0 1 8 9.344a.617.617 0 0 1-.188.453.661.661 0 0 1-.953 0L4 6.937l-2.86 2.86A.661.661 0 0 1 .657 10a.594.594 0 0 1-.453-.203A.594.594 0 0 1 0 9.344c0-.188.068-.35.203-.485l3.328-3.328A.611.611 0 0 1 4 5.328c.188 0 .344.068.469.203L7.797 8.86Z"/>
      </svg>
    </back-to-top>
  {%- endif -%}

  <div class="unionbay-footer__main section remove_spacing">
    <div class="{{ container }} unionbay-footer__container">
      {%- comment -%} Mobile newsletter (shown first on mobile) {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'newsletter' -%}
          <div class="unionbay-footer__newsletter unionbay-footer__newsletter--mobile" {{ block.shopify_attributes }}>
            {% render 'unionbay-footer-newsletter',
              block: block,
              section: section,
              show_social: section_st.show_social,
              payment_enable: section_st.payment_enable
            %}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} Desktop grid + mobile link accordions {%- endcomment -%}
      <div class="unionbay-footer__grid">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'link_list' -%}
              {%- assign block_st = block.settings -%}
              {%- if block_st.preset != blank or block_st.menu != blank -%}
                <div class="unionbay-footer__column" {{ block.shopify_attributes }}>
                  <collapsible-block tabindex="0" class="unionbay-footer__collapsible">
                    {%- if block_st.preset != blank -%}
                      {%- liquid
                        if block_st.heading != blank
                          assign mobile_heading = block_st.heading
                        else
                          case block_st.preset
                            when 'about'
                              assign mobile_heading = 'About'
                            when 'help'
                              assign mobile_heading = 'Help'
                            when 'privacy'
                              assign mobile_heading = 'Privacy Notices'
                            when 'affiliates'
                              assign mobile_heading = 'Affiliates'
                            when 'blog'
                              assign mobile_heading = 'Top Blog Posts'
                            when 'shop'
                              assign mobile_heading = 'Shop by Category'
                          endcase
                        endif
                      -%}
                      <div class="collapsible-heading relative hidden-lg">
                        <h3 class="unionbay-footer__heading">
                          <span>{{ mobile_heading | escape }}</span>
                          <span class="open-children-toggle absolute inset-0 flex flex-end">
                            <span class="icon_plus-animation"></span>
                          </span>
                        </h3>
                      </div>
                      <div class="collapsible-content unionbay-footer__links">
                        {% render 'unionbay-footer-links',
                          preset: block_st.preset,
                          heading: block_st.heading
                        %}
                      </div>
                    {%- else -%}
                      <h3 class="unionbay-footer__heading collapsible-heading relative">
                        <span>{{ block_st.heading | default: block_st.menu.title | escape }}</span>
                        <span class="open-children-toggle hidden-lg absolute inset-0 flex flex-end">
                          <span class="icon_plus-animation"></span>
                        </span>
                      </h3>
                      <div class="collapsible-content unionbay-footer__links">
                        {% render 'unionbay-footer-links',
                          heading: block_st.heading,
                          menu: block_st.menu
                        %}
                      </div>
                    {%- endif -%}
                  </collapsible-block>
                </div>
              {%- endif -%}
            {%- when 'newsletter' -%}
              <div
                class="unionbay-footer__newsletter unionbay-footer__newsletter--desktop"
                {{ block.shopify_attributes }}
              >
                {% render 'unionbay-footer-newsletter',
                  block: block,
                  section: section,
                  show_social: section_st.show_social,
                  payment_enable: section_st.payment_enable
                %}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {% render 'unionbay-footer-commitments' %}

  {%- if section_st.copyright_text != blank -%}
    <div class="unionbay-footer__copyright">
      <div class="{{ container }}">
        {{ section_st.copyright_text }}
      </div>
    </div>
  {%- endif -%}
</footer>

{%- if section_st.enable_rewards_bar -%}
  <div class="unionbay-rewards-bar" data-unionbay-rewards-bar>
    <button
      type="button"
      class="unionbay-rewards-bar__toggle"
      aria-controls="unionbay-rewards-panel"
      aria-expanded="false"
      data-unionbay-rewards-toggle
    >
      {{ 'unionbay.rewards_bar_title' | t }}
      <svg width="10" height="7" viewBox="0 0 10 7" aria-hidden="true" class="unionbay-rewards-bar__chevron">
        <path d="M5.00048 2.71932L0.942667 6.44267L0 5.5L5.00048 0.833984L10 5.5L9.05733 6.44267L5.00048 2.71932Z" fill="currentColor"/>
      </svg>
    </button>
    <div id="unionbay-rewards-panel" class="unionbay-rewards-bar__panel" hidden data-unionbay-rewards-panel>
      <button
        type="button"
        class="unionbay-rewards-bar__close"
        aria-label="{{ 'accessibility.close' | t }}"
        data-unionbay-rewards-close
      >
        <svg width="19" height="19" viewBox="0 0 19 19" fill="none" aria-hidden="true">
          <rect x="0.001" y="0.949" width="1.343" height="25.524" transform="rotate(-45 0.001 0.949)" fill="currentColor"/>
          <rect x="18.05" width="1.343" height="25.524" transform="rotate(45 18.05 0)" fill="currentColor"/>
        </svg>
      </button>
      <p class="unionbay-rewards-bar__text">{{ 'unionbay.rewards_bar_text' | t }}</p>
      <a href="{{ routes.account_register_url }}" class="unionbay-rewards-bar__cta">
        <span>
          <strong>{{ 'unionbay.rewards_bar_join' | t }}</strong>
          <span class="unionbay-rewards-bar__cta-sub">{{ 'unionbay.rewards_bar_join_sub' | t }}</span>
        </span>
        <svg width="26" height="14" viewBox="0 0 26 14" fill="none" aria-hidden="true">
          <path d="M21.8157 6.11083L17.1669 1.34283L18.3924 0.0859375L25.1333 6.99971L18.3924 13.9135L17.1669 12.6566L21.8157 7.8886H0V6.11083H21.8157Z" fill="currentColor"/>
        </svg>
      </a>
      <p class="unionbay-rewards-bar__login">
        {{ 'unionbay.rewards_bar_member' | t }}
        <a href="{{ routes.account_login_url }}">{{ 'unionbay.rewards_bar_login' | t }}</a>
      </p>
    </div>
  </div>
{%- endif -%}

{% javascript %}
  document.querySelectorAll("[data-unionbay-rewards-bar]").forEach((bar) => {
    const toggle = bar.querySelector("[data-unionbay-rewards-toggle]");
    const panel = bar.querySelector("[data-unionbay-rewards-panel]");
    const close = bar.querySelector("[data-unionbay-rewards-close]");
    if (!toggle || !panel) return;

    const setOpen = (open) => {
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
      panel.hidden = !open;
      bar.classList.toggle("is-open", open);
    };

    toggle.addEventListener("click", () => setOpen(panel.hidden));
    close?.addEventListener("click", () => setOpen(false));
  });
{% endjavascript %}

{% schema %}
{
  "name": "t:unionbay.footer.name",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "options": [
        { "value": "container", "label": "t:sections.all.section_width.container.label" },
        { "value": "fluid_container", "label": "t:sections.all.section_width.fluid_container.label" },
        { "value": "stretch_width", "label": "t:sections.all.section_width.stretch_width.label" },
        { "value": "full_width", "label": "t:sections.all.section_width.full_width.label" }
      ],
      "default": "fluid_container",
      "label": "t:sections.all.section_width.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "checkbox",
      "id": "enable_back_top",
      "default": false,
      "label": "t:sections.footer.settings.enable_back_top.label"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "default": true,
      "label": "t:sections.footer.settings.show_social.label"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "t:sections.footer.settings.payment_enable.label"
    },
    {
      "type": "checkbox",
      "id": "enable_rewards_bar",
      "default": true,
      "label": "t:unionbay.footer.rewards_bar"
    },
    {
      "type": "textarea",
      "id": "copyright_text",
      "label": "t:sections.footer.settings.copyright_text",
      "default": "©2026 Moon Style Apparel. All rights reserved."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.all.section_padding.top.label",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.all.section_padding.bottom.label",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px"
    }
  ],
  "max_blocks": 7,
  "blocks": [
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "select",
          "id": "preset",
          "label": "t:unionbay.footer.preset",
          "default": "about",
          "options": [
            { "value": "about", "label": "About" },
            { "value": "help", "label": "Help" },
            { "value": "privacy", "label": "Privacy Notices" },
            { "value": "affiliates", "label": "Affiliates" },
            { "value": "blog", "label": "Top Blog Posts" },
            { "value": "shop", "label": "Shop by Category" },
            { "value": "", "label": "Custom menu" }
          ]
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "t:sections.footer.blocks.newsletter.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Take 15% off your order when you signup!",
          "label": "t:sections.footer.blocks.newsletter.settings.heading.label"
        },
        {
          "type": "inline_richtext",
          "id": "description",
          "default": "Promo code will be emailed to you.",
          "label": "t:sections.footer.blocks.newsletter.settings.description.label"
        },
        {
          "type": "text",
          "id": "email_placeholder",
          "default": "Email address",
          "label": "t:sections.footer.blocks.newsletter.settings.email_placeholder.label"
        },
        {
          "type": "text",
          "id": "button_label",
          "default": "Submit",
          "label": "t:sections.footer.blocks.newsletter.settings.button_label.label"
        },
        {
          "type": "inline_richtext",
          "id": "note",
          "default": "By submitting your email address, you agree to receive email marketing notifications from us. You may opt out anytime.",
          "label": "t:sections.footer.blocks.newsletter.settings.note.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:unionbay.footer.name"
    }
  ]
}
{% endschema %}
