{%- liquid
  assign section_st = section.settings
  assign section_width = section_st.section_width
  assign color_scheme = section_st.color_scheme
  assign items_per_row = section_st.items_per_row
  assign items_per_row_mobile = section_st.items_per_row_mobile
  assign column_gap = section_st.column_gap
  assign show_arrow = section_st.show_arrow
  assign scroll_animation = settings.scroll_animation
-%}
{%- capture style -%}
  --section-pt: {{ section_st.padding_top }};
  --section-pb: {{ section_st.padding_bottom }};
{%- endcapture -%}
{%- capture col_style -%}
  --col-desktop: {{ items_per_row }};
  --col-number: {{ items_per_row_mobile }};
  --col-tablet: 3;
  --col-gap: 15px;
  --col-gap-desktop: {{ column_gap }}px;
  --col-mobile: {{ items_per_row_mobile }};
{%- endcapture -%}

<section
  class="section{% if section_st.padding_top < 30 %} pt-min{% endif %}{% if section_st.padding_bottom < 30 %} pb-min{% endif %} unionbay-product-tabs sec__collection-tab color-{{ color_scheme }} gradient"
  style="{{ style | strip | strip_newlines }}"
>
  <div class="{{ section_width }}">
    {%- if section.blocks.size > 0 -%}
      <tab-items data-type="horizontal">
        <div class="unionbay-product-tabs__nav mb-20">
          <div class="collection-tab__ta inline-flex align-center overflow-auto border-bottom w-full">
            {%- for block in section.blocks -%}
              {%- liquid
                assign block_st = block.settings
                assign collection_title = block_st.collection.title
                assign collection_title = block_st.collection_title | default: collection_title
              -%}
              <div
                data-block-id="{{ block.id }}"
                class="collection-tab__tab-item whitespace-nowrap pointer px-20 pb-10 transition text-center heading-style fs-16 border-animation{% if forloop.first %} active{% endif %}"
                {{ block.shopify_attributes }}
                style="--height: 2px;"
              >
                {{ collection_title | default: 'Collection' }}
              </div>
            {%- endfor -%}
          </div>
        </div>

        <div class="unionbay-product-tabs__title-row flex justify-between align-end mb-25 gap-15 flex-wrap">
          {%- if section_st.heading != blank -%}
            <h3 class="unionbay-product-tabs__heading section__header-heading h3 mt-0 mb-0">
              {{ section_st.heading }}
            </h3>
          {%- endif -%}
          {%- if section_st.shop_all_label != blank -%}
            <a href="{{ section_st.shop_all_link | default: '#' }}" class="unionbay-product-tabs__shop-all btn-link no-underline heading-style">
              {{ section_st.shop_all_label }}
            </a>
          {%- endif -%}
        </div>

        <div class="relative tab-content">
          {%- for block in section.blocks -%}
            {%- liquid
              assign block_st = block.settings
              assign collection = collections[block_st.collection]
            -%}
            <div
              class="collection-tab__tab-content absolute invisible inset-0 transition pointer-none{% if forloop.first %} active{% endif %}"
              data-block-id="{{ block.id }}"
            >
              {%- if collection != blank and collection.products.size > 0 -%}
                <slide-section
                  class="swiper"
                  data-section-id="{{ section.id }}"
                  data-block-id="{{ block.id }}"
                  data-autoplay="false"
                  data-effect="slide"
                  data-loop="false"
                  data-speed="800"
                  data-spacing="{{ column_gap }}"
                  data-mobile="{{ items_per_row_mobile }}"
                  data-tablet="3"
                  data-desktop="{{ items_per_row }}"
                  data-arrow-centerimage="1"
                  style="{{ col_style | strip | strip_newlines }}"
                >
                  {%- if show_arrow -%}
                    {%- render 'swiper-navigation' -%}
                  {%- endif -%}
                  <div class="swiper-wrapper">
                    {%- for product in collection.products limit: section_st.items_to_show -%}
                      {% render 'product-item',
                        card_product: product,
                        section_id: section.id,
                        class: ' swiper-slide',
                        template_enable_action: true,
                        template_enable_product_vendor: false,
                        template_enable_rate: false,
                        template_enable_product_short_description: false,
                        template_enable_color_swatches: false,
                        template_enable_price: true,
                        template_enable_add_cart: true,
                        template_enable_product_badges: true,
                        unionbay_mode: true,
                        scroll_animation: scroll_animation,
                        indexFor: forloop.index
                      %}
                    {%- endfor -%}
                  </div>
                </slide-section>
              {%- else -%}
                <div class="swiper-wrapper flex gap-20">
                  {%- for i in (1..4) -%}
                    {% render 'product-item',
                      section_id: section.id,
                      class: ' swiper-slide',
                      template_enable_action: true,
                      template_enable_price: true,
                      template_enable_product_badges: true,
                      unionbay_mode: true,
                      indexFor: forloop.index
                    %}
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </tab-items>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Unionbay product tabs",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:sections.all.section_width.label",
      "default": "fluid_container",
      "options": [
        { "value": "fluid_container", "label": "t:sections.all.section_width.fluid_container.label" },
        { "value": "container", "label": "t:sections.all.section_width.container.label" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.all.section_header.heading.label",
      "default": "Shop all womens"
    },
    {
      "type": "text",
      "id": "shop_all_label",
      "label": "Shop all link label",
      "default": "Shop all"
    },
    {
      "type": "url",
      "id": "shop_all_link",
      "label": "Shop all link"
    },
    {
      "type": "range",
      "id": "items_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "t:sections.all.items.items_to_show.label"
    },
    {
      "type": "range",
      "id": "items_per_row",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "t:sections.all.items.items_per_row.label"
    },
    {
      "type": "range",
      "id": "items_per_row_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2,
      "label": "t:sections.all.items.items_per_row_mobile.label"
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 10,
      "max": 40,
      "step": 5,
      "default": 20,
      "unit": "px",
      "label": "t:sections.all.items.column_gap.label"
    },
    {
      "type": "checkbox",
      "id": "show_arrow",
      "label": "t:sections.all.carousel_settings.show-next-back.label",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "limit": 5,
      "name": "t:sections.collection-tab.blocks.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.collection-tab.blocks.collection"
        },
        {
          "type": "text",
          "id": "collection_title",
          "label": "t:sections.collection-tab.blocks.collection_title.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Unionbay product tabs",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
