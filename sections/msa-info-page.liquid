{%- liquid
  assign section_st = section.settings
  assign section_width = section_st.section_width
-%}

{%- capture style -%}
  --section-pt: {{ section_st.padding_top }}px;
  --section-pb: {{ section_st.padding_bottom }}px;
{%- endcapture -%}

<div
  class="section msa-page{% if section_st.padding_top < 30 %} pt-min{% endif %}{% if section_st.padding_bottom < 30 %} pb-min{% endif %}"
  style="{{ style | strip | strip_newlines }}"
>
  <div class="{{ section_width }}">
    {%- assign cards_open = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'card' -%}
        {%- unless cards_open -%}
          <div class="msa-page__cards grid grid-cols gap" style="--col-desktop: 3; --col-tablet: 2; --col-number: 1;">
          {%- assign cards_open = true -%}
        {%- endunless -%}
        <div class="msa-page__card" {{ block.shopify_attributes }}>
          {%- if block.settings.title != blank -%}
            <h4 class="msa-page__card-title">{{ block.settings.title }}</h4>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="msa-page__card-text rte">{{ block.settings.text }}</div>
          {%- endif -%}
        </div>
      {%- else -%}
        {%- if cards_open -%}
          </div>
          {%- assign cards_open = false -%}
        {%- endif -%}
        {%- case block.type -%}
        {%- when 'intro' -%}
          <div class="msa-page__intro" {{ block.shopify_attributes }}>
            {%- if block.settings.subheading != blank -%}
              <p class="msa-page__eyebrow">{{ block.settings.subheading }}</p>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h2 class="msa-page__heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="msa-page__text rte">{{ block.settings.text }}</div>
            {%- endif -%}
          </div>

        {%- when 'content' -%}
          <div class="msa-page__block" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="msa-page__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <div class="msa-page__text rte">{{ block.settings.body }}</div>
            {%- endif -%}
          </div>

        {%- when 'list' -%}
          <div class="msa-page__block" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="msa-page__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.items != blank -%}
              <ul class="msa-page__list list-unstyled">
                {%- assign list_items = block.settings.items | newline_to_br | split: '<br />' -%}
                {%- for item in list_items -%}
                  {%- assign item_clean = item | strip -%}
                  {%- if item_clean != blank -%}
                    <li class="msa-page__list-item">{{ item_clean }}</li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

        {%- when 'cards_grid' -%}
          <div class="msa-page__block" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="msa-page__title msa-page__title--center">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.subtitle != blank -%}
              <p class="msa-page__subtitle msa-page__subtitle--center">{{ block.settings.subtitle }}</p>
            {%- endif -%}
          </div>

        {%- when 'testimonial' -%}
          <blockquote class="msa-page__testimonial" {{ block.shopify_attributes }}>
            {%- if block.settings.quote != blank -%}
              <p class="msa-page__quote">{{ block.settings.quote }}</p>
            {%- endif -%}
            {%- if block.settings.author != blank -%}
              <cite class="msa-page__author">{{ block.settings.author }}</cite>
            {%- endif -%}
          </blockquote>

        {%- when 'offices' -%}
          <div class="msa-page__offices grid grid-cols gap" style="--col-desktop: 2; --col-tablet: 2; --col-number: 1;" {{ block.shopify_attributes }}>
            <div class="msa-page__office">
              {%- if block.settings.office_1_title != blank -%}
                <h3 class="msa-page__office-title">{{ block.settings.office_1_title }}</h3>
              {%- endif -%}
              {%- if block.settings.office_1_address != blank -%}
                <p class="msa-page__office-address">{{ block.settings.office_1_address }}</p>
              {%- endif -%}
            </div>
            <div class="msa-page__office">
              {%- if block.settings.office_2_title != blank -%}
                <h3 class="msa-page__office-title">{{ block.settings.office_2_title }}</h3>
              {%- endif -%}
              {%- if block.settings.office_2_address != blank -%}
                <p class="msa-page__office-address">{{ block.settings.office_2_address }}</p>
              {%- endif -%}
            </div>
          </div>

        {%- when 'certifications' -%}
          <div class="msa-page__block" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="msa-page__title msa-page__title--center">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.certs != blank -%}
              <ul class="msa-page__certs list-unstyled flex flex-wrap justify-center gap-15">
                {%- assign cert_list = block.settings.certs | split: ',' -%}
                {%- for cert in cert_list -%}
                  {%- assign cert_clean = cert | strip -%}
                  {%- if cert_clean != blank -%}
                    <li class="msa-page__cert">{{ cert_clean }}</li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

        {%- when 'page_content' -%}
          {%- if page.content != blank -%}
            <div class="msa-page__block msa-page__page-content rte" {{ block.shopify_attributes }}>
              {{ page.content }}
            </div>
          {%- elsif block.settings.fallback != blank -%}
            <div class="msa-page__block msa-page__page-content rte" {{ block.shopify_attributes }}>
              {{ block.settings.fallback }}
            </div>
          {%- endif -%}
        {%- endcase -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if cards_open -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .msa-page {
    padding-top: var(--section-pt, 40px);
    padding-bottom: var(--section-pb, 60px);
    color: #1a1a1a;
  }

  .msa-page__intro {
    max-width: 900px;
    margin: 0 auto 40px;
    text-align: center;
  }

  .msa-page__eyebrow {
    color: #e85d04;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 12px;
  }

  .msa-page__heading {
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    font-weight: 800;
    color: #1a3a6b;
    margin: 0 0 20px;
    line-height: 1.15;
  }

  .msa-page__title {
    font-size: 2rem;
    font-weight: 700;
    color: #1a3a6b;
    margin: 0 0 16px;
  }

  .msa-page__title--center,
  .msa-page__subtitle--center {
    text-align: center;
  }

  .msa-page__subtitle {
    color: #555;
    margin: -8px 0 28px;
    font-size: 1.5rem;
  }

  .msa-page__block {
    max-width: 900px;
    margin: 0 auto 36px;
  }

  .msa-page__text {
    font-size: 1.5rem;
    line-height: 1.75;
    color: #333;
  }

  .msa-page__text p {
    margin-bottom: 1.2em;
  }

  .msa-page__list {
    margin: 0;
    padding: 0;
  }

  .msa-page__list-item {
    position: relative;
    padding-left: 22px;
    margin-bottom: 12px;
    font-size: 1.5rem;
    line-height: 1.6;
  }

  .msa-page__list-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #e85d04;
  }

  .msa-page__cards {
    margin-top: 10px;
  }

  .msa-page__card {
    background: #f8f9fb;
    border: 1px solid #e8ecf2;
    border-radius: 4px;
    padding: 24px;
    height: 100%;
  }

  .msa-page__card-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: #1a3a6b;
    margin: 0 0 10px;
  }

  .msa-page__card-text {
    font-size: 1.4rem;
    line-height: 1.65;
    color: #444;
  }

  .msa-page__testimonial {
    max-width: 760px;
    margin: 0 auto 24px;
    padding: 24px 28px;
    background: #fff;
    border-left: 4px solid #e85d04;
    box-shadow: 0 2px 12px rgba(26, 58, 107, 0.08);
  }

  .msa-page__quote {
    font-size: 1.5rem;
    line-height: 1.7;
    margin: 0 0 10px;
    font-style: italic;
    color: #333;
  }

  .msa-page__author {
    font-size: 1.3rem;
    font-weight: 700;
    color: #1a3a6b;
    font-style: normal;
  }

  .msa-page__offices {
    margin: 0 auto 36px;
    max-width: 900px;
  }

  .msa-page__office {
    background: #f8f9fb;
    border: 1px solid #e8ecf2;
    padding: 28px;
    border-radius: 4px;
  }

  .msa-page__office-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: #1a3a6b;
    margin: 0 0 10px;
  }

  .msa-page__office-address {
    font-size: 1.5rem;
    line-height: 1.7;
    margin: 0;
    color: #444;
  }

  .msa-page__certs {
    margin: 0;
    padding: 0;
  }

  .msa-page__cert {
    background: #1a3a6b;
    color: #fff;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 10px 16px;
    border-radius: 4px;
  }

  @media (max-width: 767px) {
    .msa-page__cards {
      --col-desktop: 1;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MSA info page",
  "tag": "section",
  "class": "section-msa-info",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:sections.all.section_width.label",
      "default": "fluid_container",
      "options": [
        { "value": "container", "label": "t:sections.all.section_width.container.label" },
        { "value": "fluid_container", "label": "t:sections.all.section_width.fluid_container.label" },
        { "value": "stretch_width", "label": "t:sections.all.section_width.stretch_width.label" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.section_padding.top.label",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.section_padding.bottom.label",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "intro",
      "name": "Intro",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "subheading", "label": "Eyebrow" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "richtext", "id": "text", "label": "Text" }
      ]
    },
    {
      "type": "content",
      "name": "Content",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "body", "label": "Body" }
      ]
    },
    {
      "type": "list",
      "name": "Bullet list",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "items", "label": "Items", "info": "One item per line" }
      ]
    },
    {
      "type": "cards_grid",
      "name": "Cards section heading",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "subtitle", "label": "Subtitle" }
      ]
    },
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "text", "label": "Text" }
      ]
    },
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "author", "label": "Author" }
      ]
    },
    {
      "type": "offices",
      "name": "Office locations",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "office_1_title", "label": "Office 1 title", "default": "Pakistan office" },
        { "type": "textarea", "id": "office_1_address", "label": "Office 1 address" },
        { "type": "text", "id": "office_2_title", "label": "Office 2 title", "default": "Europe office" },
        { "type": "textarea", "id": "office_2_address", "label": "Office 2 address" }
      ]
    },
    {
      "type": "certifications",
      "name": "Certifications",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Vendor certifications" },
        { "type": "text", "id": "certs", "label": "Certifications", "info": "Comma-separated list" }
      ]
    },
    {
      "type": "page_content",
      "name": "Page content",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "fallback",
          "label": "Fallback content",
          "info": "Shown when the page body is empty in admin."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MSA info page"
    }
  ]
}
{% endschema %}
