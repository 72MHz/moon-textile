<div class="msa-size-recommender-page page-width">
  <div class="msa-size-recommender-page__inner">
    {% if section.settings.heading != blank %}
      <h2 class="msa-size-recommender-page__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.intro != blank %}
      <div class="msa-size-recommender-page__intro rte">{{ section.settings.intro }}</div>
    {% endif %}
    {% render 'size-recommender', section: section, standalone: true %}
  </div>
</div>

{% stylesheet %}
  .msa-size-recommender-page {
    padding: 20px 0 60px;
  }

  .msa-size-recommender-page__inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .msa-size-recommender-page__heading {
    font-size: 2.4rem;
    font-weight: 700;
    margin: 0 0 12px;
    color: #1a3a6b;
  }

  .msa-size-recommender-page__intro {
    margin-bottom: 24px;
    font-size: 1.5rem;
    line-height: 1.7;
    color: #444;
  }

  .msa-size-recommender-page .size-recommender__trigger {
    display: none;
  }

  .msa-size-recommender-page .size-recommender__content {
    display: block !important;
  }

  .msa-size-recommender-page .size-recommender__form {
    padding: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Size recommender",
  "tag": "section",
  "class": "section-msa-size-recommender",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find your size"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Introduction",
      "default": "<p>Answer a few questions and we'll suggest the best size for you.</p>"
    }
  ],
  "presets": [
    {
      "name": "Size recommender"
    }
  ]
}
{% endschema %}
