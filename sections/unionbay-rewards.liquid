{%- liquid
  assign section_st = section.settings
  assign section_width = section_st.section_width
  assign color_scheme = section_st.color_scheme
  assign image = section_st.image
  assign image_mobile = section_st.image_mobile | default: image
-%}
{%- capture style -%}
  --section-pt: {{ section_st.padding_top }};
  --section-pb: {{ section_st.padding_bottom }};
  --overlay-opacity: {{ section_st.overlay_opacity }}%;
  --height: {{ section_st.mobile_height }}px;
  --height-desktop: {{ section_st.desktop_height }}px;
{%- endcapture -%}

<section
  class="section unionbay-rewards sec__iwto color-{{ color_scheme }} gradient{% if section_st.padding_top < 30 %} pt-min{% endif %}{% if section_st.padding_bottom < 30 %} pb-min{% endif %}"
  style="{{ style | strip | strip_newlines }}"
>
  <div class="{{ section_width }}">
    <div class="unionbay-rewards__inner sec__inner flex relative h-custom overflow-hidden">
      <div class="banner__media w-full overlay-bg absolute inset-0">
        {%- if image != blank or image_mobile != blank -%}
          {% render 'responsive-image',
            type: 'banner',
            container: section_width,
            image: image,
            image_mobile: image_mobile,
            image_alt: section_st.heading,
            no_animate: true
          %}
        {%- else -%}
          <img
            src="{{ 'ub-rewards.jpg' | asset_url }}"
            alt="{{ section_st.heading | escape }}"
            class="absolute inset-0 w-full h-full object-fit-cover unionbay-fallback-image"
            loading="lazy"
            decoding="async"
            width="1600"
            height="900"
          >
        {%- endif -%}
      </div>
      <div class="sec__content relative z-1 w-full flex middle-center text-center">
        <div class="unionbay-rewards__content sec__content-inner">
          {%- if section_st.subheading != blank -%}
            <h2 class="unionbay-rewards__subheading mt-0">{{ section_st.subheading }}</h2>
          {%- endif -%}
          {%- if section_st.heading != blank -%}
            <h1 class="unionbay-rewards__heading mt-0">{{ section_st.heading }}</h1>
          {%- endif -%}
          {%- if section_st.description != blank -%}
            <p class="unionbay-rewards__description">{{ section_st.description }}</p>
          {%- endif -%}
          {%- if section_st.button_label != blank -%}
            <a href="{{ section_st.button_link | default: '#' }}" class="unionbay-rewards__button">
              {{ section_st.button_label }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Unionbay rewards banner",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:sections.all.section_width.label",
      "default": "full_width",
      "options": [
        { "value": "full_width", "label": "t:sections.all.section_width.full_width.label" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "t:sections.all.overlay_opacity.label",
      "default": 30
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 300,
      "max": 700,
      "step": 10,
      "unit": "px",
      "label": "Desktop height",
      "default": 420
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 250,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Mobile height",
      "default": 360
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Earn Rewards!"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.all.section_header.heading.label",
      "default": "Earn points for every $1 spent!"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.all.contents.description.label",
      "default": "Based on your tier, you will get 5-10 points on every dollar spent. Plus, special birthday rewards!"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "JOIN THE CLUB"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Unionbay rewards banner"
    }
  ]
}
{% endschema %}
