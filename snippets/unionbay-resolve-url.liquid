{% doc %}
  Resolves shop-all / collection URLs that may point to missing collections.

  @param {string} [url] - URL from theme settings
  @param {string} [shop_type] - women or men
{% enddoc %}

{%- liquid
  assign department = shop_type | default: 'women' | strip | downcase
  assign resolved = ''

  if department == 'men'
    if collections['men-shop-all'] != blank
      assign resolved = collections['men-shop-all'].url
    else
      assign resolved = '/collections/men-shop-all'
    endif
  else
    if collections['women-shop-all'] != blank
      assign resolved = collections['women-shop-all'].url
    else
      assign resolved = '/collections/women-shop-all'
    endif
  endif

  assign custom_url = url | default: ''
  if custom_url contains 'women-shop-all' and collections['women-shop-all'] != blank
    assign resolved = collections['women-shop-all'].url
  endif
  if custom_url contains 'men-shop-all' and collections['men-shop-all'] != blank
    assign resolved = collections['men-shop-all'].url
  endif
  if custom_url contains 'womens-clothing-shop-all' and collections['women-shop-all'] != blank
    assign resolved = collections['women-shop-all'].url
  endif
  if custom_url contains 'mens-clothing-shop-all' and collections['men-shop-all'] != blank
    assign resolved = collections['men-shop-all'].url
  endif
-%}
{{- resolved -}}
