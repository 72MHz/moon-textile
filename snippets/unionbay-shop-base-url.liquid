{% doc %}
  Resolves a working shop-all base URL with fallbacks.

  @param {string} shop_type - women or men
{% enddoc %}

{%- liquid
  assign resolved_url = routes.all_products_collection_url
  assign shop_type = shop_type | strip | downcase

  if shop_type == 'men'
    if collections['men-shop-all'] != blank
      assign resolved_url = collections['men-shop-all'].url
    else
      assign resolved_url = '/collections/men-shop-all'
    endif
  else
    if collections['women-shop-all'] != blank
      assign resolved_url = collections['women-shop-all'].url
    else
      assign resolved_url = '/collections/women-shop-all'
    endif
  endif
-%}
{{- resolved_url -}}
