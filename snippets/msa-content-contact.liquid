{% doc %}
  Contact page — accessible contact form.
{% enddoc %}

{{ 'page-contact.css' | asset_url | stylesheet_tag }}

<div class="section msa-contact-section">
  <div class="fluid_container">
    <div class="msa-contact-card">
      <header class="msa-contact-card__header">
        <p class="msa-contact-card__eyebrow">{{ 'templates.contact.form.eyebrow' | t }}</p>
        <h2 class="msa-contact-card__title">{{ 'templates.contact.form.title' | t }}</h2>
        <p class="msa-contact-card__subtitle">{{ 'templates.contact.form.intro' | t }}</p>
      </header>

      {% form 'contact', id: 'MsaContactForm', class: 'msa-contact-form' %}
        {% if form.posted_successfully? %}
          <div class="msa-contact-form__success" role="status">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
              <circle cx="11" cy="11" r="10" stroke="currentColor" stroke-width="1.5"/>
              <path d="M6.5 11.2l2.8 2.8 6.2-6.2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <p>{{ 'general.contact.success' | t }}</p>
          </div>
        {% else %}
          {% if form.errors != blank %}
            <div class="msa-contact-form__errors" role="alert">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}

          <p class="msa-contact-form__required-note">
            {{ 'templates.contact.form.required_note' | t }}
          </p>

          <div class="msa-contact-form__grid">
            <div class="msa-contact-form__field">
              <label class="msa-contact-form__label" for="MsaContactName">
                {{ 'templates.contact.form.name' | t }}
                <span class="msa-contact-form__required" aria-hidden="true">*</span>
              </label>
              <input
                class="msa-contact-form__input"
                type="text"
                name="contact[name]"
                id="MsaContactName"
                autocomplete="name"
                required
                aria-required="true"
                placeholder="{{ 'templates.contact.form.name_placeholder' | t }}"
              >
            </div>

            <div class="msa-contact-form__field">
              <label class="msa-contact-form__label" for="MsaContactEmail">
                {{ 'templates.contact.form.email' | t }}
                <span class="msa-contact-form__required" aria-hidden="true">*</span>
              </label>
              <input
                class="msa-contact-form__input"
                type="email"
                name="contact[email]"
                id="MsaContactEmail"
                autocomplete="email"
                required
                aria-required="true"
                placeholder="{{ 'templates.contact.form.email_placeholder' | t }}"
              >
            </div>

            <div class="msa-contact-form__field">
              <label class="msa-contact-form__label" for="MsaContactPhone">
                {{ 'templates.contact.form.phone' | t }}
                <span class="msa-contact-form__optional">{{ 'templates.contact.form.optional' | t }}</span>
              </label>
              <input
                class="msa-contact-form__input"
                type="tel"
                name="contact[phone]"
                id="MsaContactPhone"
                autocomplete="tel"
                placeholder="{{ 'templates.contact.form.phone_placeholder' | t }}"
              >
            </div>

            <div class="msa-contact-form__field msa-contact-form__field--full">
              <label class="msa-contact-form__label" for="MsaContactBody">
                {{ 'templates.contact.form.comment' | t }}
                <span class="msa-contact-form__required" aria-hidden="true">*</span>
              </label>
              <textarea
                class="msa-contact-form__input msa-contact-form__textarea"
                name="contact[body]"
                id="MsaContactBody"
                rows="6"
                required
                aria-required="true"
                placeholder="{{ 'templates.contact.form.comment_placeholder' | t }}"
              ></textarea>
            </div>
          </div>

          <div class="msa-contact-form__actions">
            <button type="submit" class="msa-contact-form__submit">
              {{ 'templates.contact.form.send_contact' | t }}
            </button>
            <p class="msa-contact-form__privacy">
              {{ 'templates.contact.form.privacy_note_html' | t }}
            </p>
          </div>
        {% endif %}
      {% endform %}
    </div>
  </div>
</div>
