{% doc %}
  Contact page body with offices and contact form.
{% enddoc %}

{{ 'page-contact.css' | asset_url | stylesheet_tag }}

<div class="section msa-page" style="--section-pt: 8px; --section-pb: 0;">
  <div class="fluid_container">
    <div class="msa-page__offices grid grid-cols gap" style="--col-desktop: 2; --col-tablet: 2; --col-number: 1;">
      <div class="msa-page__office">
        <h3 class="msa-page__office-title">Pakistan office</h3>
        <p class="msa-page__office-address">MashaAllah Center, 2nd Floor, Sunflower Housing Society, J-1, Johar Town, Lahore, Pakistan</p>
      </div>
      <div class="msa-page__office">
        <h3 class="msa-page__office-title">Europe office</h3>
        <p class="msa-page__office-address">Rainham, London, United Kingdom</p>
      </div>
    </div>
  </div>
</div>

<div class="section sec__collection-list" style="--section-pt: 20px; --section-pb: 60px;">
  <div class="fluid_container">
    <div class="flex flex-wrap contact-container" style="--column_gap: 60px;">
      <div class="support_customer flex-1">
        <h3 class="section__header-heading h4 heading-letter-spacing mt-0">Get in touch</h3>
        <div class="section__header-des rich__text-m0 mb-25">
          <p>Reach out to Moon Style Apparel for sourcing, manufacturing partnerships, or general enquiries.</p>
        </div>
        <div class="rte">
          <p><strong>Pakistan office</strong><br>MashaAllah Center, 2nd Floor<br>Sunflower Housing Society, J-1<br>Johar Town, Lahore, Pakistan</p>
          <p><strong>Europe office</strong><br>Rainham, London<br>United Kingdom</p>
        </div>
      </div>
      <div class="contact_form flex-1">
        <h3 class="section__header-heading h4 heading-letter-spacing mt-0">Send message</h3>
        <div class="section__header-des rich__text-m0 mb-25">
          <p>Fill out the form and our team will get back to you shortly.</p>
        </div>
        {% form 'contact', id: 'MsaContactForm' %}
          {% if form.posted_successfully? %}
            <p class="success inline-flex gap-10 align-center lh-normal">{{ 'general.contact.success' | t }}</p>
          {% else %}
            {{ form.errors | default_errors }}
            <div class="flex flex-cols flex-wrap gap-20" style="--col-number: 1;">
              <div class="form-group w-full">
                <input class="form-control" type="text" name="contact[name]" id="MsaContactName" placeholder="Your name" required>
              </div>
              <div class="form-group w-full">
                <input class="form-control" type="email" name="contact[email]" id="MsaContactEmail" placeholder="Your email" required>
              </div>
              <div class="form-group w-full">
                <textarea class="form-control" name="contact[body]" id="MsaContactBody" rows="6" placeholder="Your message" required></textarea>
              </div>
              <button type="submit" class="btn btn-primary">Submit</button>
            </div>
          {% endif %}
        {% endform %}
      </div>
    </div>
  </div>
</div>
