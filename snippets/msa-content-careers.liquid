{% doc %}
  Careers page for Moon Apparel — inspired by corporate careers layouts.
{% enddoc %}

<div class="section moon-careers" style="--section-pt: 0px; --section-pb: 0px;">
  {%- comment -%} Hero {%- endcomment -%}
  <section class="moon-careers__hero">
    <div class="moon-careers__hero-media">
      <img
        src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?auto=format&fit=crop&w=1600&q=80"
        alt="Moon Apparel team collaborating in the workplace"
        loading="eager"
        width="1600"
        height="900"
      >
      <div class="moon-careers__hero-overlay"></div>
    </div>
    <div class="moon-careers__hero-content fluid_container">
      <p class="moon-careers__eyebrow">Careers</p>
      <h1 class="moon-careers__hero-title">Life at Moon Apparel</h1>
      <p class="moon-careers__hero-text">
        At Moon Apparel, we hold our ideas to a high standard and ourselves to high character.
        We coach, mentor, and bring our best selves to work every day. Whether you’re here to lead
        yourself, a team, or the next chapter of our brand, you’ll have a voice at Moon Apparel.
      </p>
      <a href="/pages/contact-us" class="moon-careers__btn moon-careers__btn--light">Explore opportunities</a>
    </div>
  </section>

  {%- comment -%} Where we work {%- endcomment -%}
  <section class="moon-careers__section fluid_container">
    <div class="moon-careers__section-head">
      <h2 class="moon-careers__heading">Where we work</h2>
      <p class="moon-careers__lead">
        Moon Apparel associates work across our studio offices, retail and online teams, and manufacturing
        partners — building stylish, comfortable clothing for everyday living.
      </p>
    </div>

    <div class="moon-careers__places">
      <article class="moon-careers__place">
        <div class="moon-careers__place-media">
          <img
            src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1000&q=80"
            alt="Moon Apparel studio office workspace"
            loading="lazy"
            width="800"
            height="560"
          >
        </div>
        <div class="moon-careers__place-body">
          <h3 class="moon-careers__place-title">Studio offices</h3>
          <p class="moon-careers__place-text">
            Our UK studio teams bring Moon Apparel to life — from product design and merchandising to
            digital, marketing, and customer experience. It’s a collaborative space where ideas move
            quickly from concept to collection.
          </p>
          <a href="/pages/contact-us" class="moon-careers__link">Explore office opportunities</a>
        </div>
      </article>

      <article class="moon-careers__place">
        <div class="moon-careers__place-media">
          <img
            src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&w=1000&q=80"
            alt="Retail clothing store environment"
            loading="lazy"
            width="800"
            height="560"
          >
        </div>
        <div class="moon-careers__place-body">
          <h3 class="moon-careers__place-title">Brand &amp; retail experience</h3>
          <p class="moon-careers__place-text">
            Our brand teams stay close to the customer through digital storefronts and community.
            From styling and content to customer care, this group creates welcoming Moon Apparel
            experiences every day.
          </p>
          <a href="/pages/contact-us" class="moon-careers__link">Explore brand opportunities</a>
        </div>
      </article>

      <article class="moon-careers__place">
        <div class="moon-careers__place-media">
          <img
            src="https://images.unsplash.com/photo-1558769132-cb1aea458c5e?auto=format&fit=crop&w=1000&q=80"
            alt="Apparel production and design workspace"
            loading="lazy"
            width="800"
            height="560"
          >
        </div>
        <div class="moon-careers__place-body">
          <h3 class="moon-careers__place-title">Production &amp; supply</h3>
          <p class="moon-careers__place-text">
            Working closely with Moon Style Textile and trusted partners, our production and quality
            teams oversee craftsmanship, ethical standards, and reliable delivery — so every garment
            meets the Moon Apparel promise.
          </p>
          <a href="/pages/contact-us" class="moon-careers__link">Explore production opportunities</a>
        </div>
      </article>
    </div>
  </section>

  {%- comment -%} Culture / purpose {%- endcomment -%}
  <section class="moon-careers__culture">
    <div class="fluid_container">
      <div class="moon-careers__culture-grid">
        <div class="moon-careers__culture-copy">
          <p class="moon-careers__eyebrow moon-careers__eyebrow--light">Our purpose in action</p>
          <h2 class="moon-careers__heading moon-careers__heading--light">Join a culture built on craft and character</h2>
          <p class="moon-careers__lead moon-careers__lead--light">
            We bring together people of all backgrounds and empower them to make an impact — at work,
            with our customers, and in the communities we support through education initiatives like SAVE DC.
          </p>
        </div>
        <ul class="moon-careers__badges list-unstyled">
          <li class="moon-careers__badge">
            <span class="moon-careers__badge-label">Established</span>
            <strong class="moon-careers__badge-value">2012</strong>
          </li>
          <li class="moon-careers__badge">
            <span class="moon-careers__badge-label">UK-based retailer</span>
            <strong class="moon-careers__badge-value">Moon Apparel</strong>
          </li>
          <li class="moon-careers__badge">
            <span class="moon-careers__badge-label">Community partner</span>
            <strong class="moon-careers__badge-value">SAVE DC</strong>
          </li>
        </ul>
      </div>
    </div>
  </section>

  {%- comment -%} Featured opportunities {%- endcomment -%}
  <section class="moon-careers__section fluid_container">
    <div class="moon-careers__section-head moon-careers__section-head--left">
      <h2 class="moon-careers__heading">Featured opportunities</h2>
      <p class="moon-careers__lead moon-careers__lead--left">
        Our teams are growing across product, digital, operations, and customer experience — helping
        Moon Apparel deliver quality clothing with an exceptional shopping experience.
      </p>
    </div>

    <div class="moon-careers__jobs">
      <a class="moon-careers__job" href="/pages/contact-us">
        <span class="moon-careers__job-area">Merchandising</span>
        <h3 class="moon-careers__job-title">Product &amp; merchandising roles</h3>
        <p class="moon-careers__job-text">Shape collections, trends, and everyday essentials customers love to wear.</p>
        <span class="moon-careers__job-cta">Apply via contact form</span>
      </a>
      <a class="moon-careers__job" href="/pages/contact-us">
        <span class="moon-careers__job-area">Digital</span>
        <h3 class="moon-careers__job-title">E‑commerce &amp; digital roles</h3>
        <p class="moon-careers__job-text">Improve the online experience, content, and tools behind moonapparel shopping.</p>
        <span class="moon-careers__job-cta">Apply via contact form</span>
      </a>
      <a class="moon-careers__job" href="/pages/contact-us">
        <span class="moon-careers__job-area">Operations</span>
        <h3 class="moon-careers__job-title">Quality, logistics &amp; support</h3>
        <p class="moon-careers__job-text">Keep product quality high and fulfilment reliable from production to doorstep.</p>
        <span class="moon-careers__job-cta">Apply via contact form</span>
      </a>
    </div>
  </section>

  {%- comment -%} Testimonials {%- endcomment -%}
  <section class="moon-careers__voices">
    <div class="fluid_container">
      <div class="moon-careers__section-head">
        <h2 class="moon-careers__heading">Hear from the team</h2>
      </div>
      <div class="moon-careers__quotes">
        <blockquote class="moon-careers__quote">
          <p>
            “Moon Apparel has the best people and work culture. The environment is open and welcoming —
            a place designed for anybody to show up as their true, authentic selves.”
          </p>
          <cite>
            <strong>Aisha R.</strong>
            <span>Product development</span>
          </cite>
        </blockquote>
        <blockquote class="moon-careers__quote">
          <p>
            “My favourite part about working at Moon Apparel is the culture. Every day I work with people
            who care about quality, customers, and doing things the right way.”
          </p>
          <cite>
            <strong>James K.</strong>
            <span>Merchandising</span>
          </cite>
        </blockquote>
      </div>
    </div>
  </section>

  {%- comment -%} Closing CTA {%- endcomment -%}
  <section class="moon-careers__cta">
    <div class="fluid_container moon-careers__cta-inner">
      <h2 class="moon-careers__heading moon-careers__heading--light">Ready to join Moon Apparel?</h2>
      <p class="moon-careers__lead moon-careers__lead--light">
        Send your CV and a short cover letter through our contact form. Tell us the role you’re excited about —
        we’d love to hear from you.
      </p>
      <a href="/pages/contact-us" class="moon-careers__btn moon-careers__btn--light">Contact Moon Apparel</a>
    </div>
  </section>
</div>

{% stylesheet %}
  .moon-careers {
    color: #1a1a1a;
  }

  .moon-careers__eyebrow {
    margin: 0 0 1.2rem;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #e85d04;
  }

  .moon-careers__eyebrow--light {
    color: #ffb98a;
  }

  .moon-careers__heading {
    margin: 0 0 1.6rem;
    font-size: clamp(2.6rem, 4vw, 4.2rem);
    line-height: 1.1;
    font-weight: 800;
    color: #1a3a6b;
  }

  .moon-careers__heading--light {
    color: #fff;
  }

  .moon-careers__lead {
    margin: 0 auto;
    max-width: 72rem;
    font-size: 1.6rem;
    line-height: 1.7;
    color: #444;
  }

  .moon-careers__lead--left {
    margin-left: 0;
  }

  .moon-careers__lead--light {
    color: #d9e2f2;
  }

  .moon-careers__section {
    padding: 7rem 0;
  }

  .moon-careers__section-head {
    text-align: center;
    margin-bottom: 4rem;
  }

  .moon-careers__section-head--left {
    text-align: left;
  }

  /* Hero */
  .moon-careers__hero {
    position: relative;
    min-height: clamp(42rem, 70vh, 62rem);
    display: flex;
    align-items: flex-end;
    color: #fff;
    overflow: hidden;
  }

  .moon-careers__hero-media {
    position: absolute;
    inset: 0;
  }

  .moon-careers__hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .moon-careers__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10, 20, 40, 0.25) 0%, rgba(10, 20, 40, 0.78) 100%);
  }

  .moon-careers__hero-content {
    position: relative;
    z-index: 1;
    padding-bottom: clamp(3.5rem, 8vw, 7rem);
    max-width: 80rem;
  }

  .moon-careers__hero-title {
    margin: 0 0 1.6rem;
    font-size: clamp(3.4rem, 7vw, 6.4rem);
    line-height: 1.02;
    font-weight: 800;
    color: #fff;
  }

  .moon-careers__hero-text {
    margin: 0 0 2.4rem;
    max-width: 62rem;
    font-size: 1.7rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.92);
  }

  .moon-careers__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 4.8rem;
    padding: 0 2.4rem;
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
    border: 1px solid transparent;
  }

  .moon-careers__btn--light {
    background: #fff;
    color: #1a3a6b;
  }

  .moon-careers__btn--light:hover {
    background: #f2f2f2;
  }

  /* Places */
  .moon-careers__places {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2.4rem;
  }

  .moon-careers__place {
    background: #f8f9fb;
    border: 1px solid #e8ecf2;
    overflow: hidden;
  }

  .moon-careers__place-media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .moon-careers__place-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .moon-careers__place-body {
    padding: 2.4rem;
  }

  .moon-careers__place-title {
    margin: 0 0 1rem;
    font-size: 2rem;
    font-weight: 700;
    color: #1a3a6b;
  }

  .moon-careers__place-text {
    margin: 0 0 1.8rem;
    font-size: 1.45rem;
    line-height: 1.65;
    color: #444;
  }

  .moon-careers__link {
    font-size: 1.35rem;
    font-weight: 700;
    color: #e85d04;
    text-decoration: none;
  }

  .moon-careers__link:hover {
    text-decoration: underline;
  }

  /* Culture */
  .moon-careers__culture {
    background: #1a3a6b;
    padding: 7rem 0;
  }

  .moon-careers__culture-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(0, 0.9fr);
    gap: 4rem;
    align-items: center;
  }

  .moon-careers__culture-copy .moon-careers__lead {
    margin-left: 0;
  }

  .moon-careers__badges {
    display: grid;
    gap: 1.2rem;
    margin: 0;
    padding: 0;
  }

  .moon-careers__badge {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.16);
    padding: 2rem 2.2rem;
  }

  .moon-careers__badge-label {
    display: block;
    margin-bottom: 0.6rem;
    font-size: 1.2rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #ffb98a;
  }

  .moon-careers__badge-value {
    display: block;
    font-size: 2rem;
    color: #fff;
  }

  /* Jobs */
  .moon-careers__jobs {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
  }

  .moon-careers__job {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 2.8rem 2.4rem;
    text-decoration: none;
    background: #fff;
    border: 1px solid #e8ecf2;
    border-top: 3px solid #e85d04;
    color: inherit;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .moon-careers__job:hover {
    border-color: #1a3a6b;
    transform: translateY(-2px);
  }

  .moon-careers__job-area {
    margin-bottom: 1rem;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #e85d04;
  }

  .moon-careers__job-title {
    margin: 0 0 1rem;
    font-size: 2rem;
    color: #1a3a6b;
  }

  .moon-careers__job-text {
    margin: 0 0 2rem;
    flex: 1;
    font-size: 1.45rem;
    line-height: 1.6;
    color: #555;
  }

  .moon-careers__job-cta {
    font-size: 1.3rem;
    font-weight: 700;
    color: #1a3a6b;
  }

  /* Quotes */
  .moon-careers__voices {
    background: #f8f9fb;
    padding: 7rem 0;
  }

  .moon-careers__quotes {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2.4rem;
  }

  .moon-careers__quote {
    margin: 0;
    padding: 3rem;
    background: #fff;
    border-left: 4px solid #e85d04;
    box-shadow: 0 2px 16px rgba(26, 58, 107, 0.06);
  }

  .moon-careers__quote p {
    margin: 0 0 2rem;
    font-size: 1.7rem;
    line-height: 1.7;
    font-style: italic;
    color: #333;
  }

  .moon-careers__quote cite {
    display: block;
    font-style: normal;
  }

  .moon-careers__quote strong {
    display: block;
    font-size: 1.4rem;
    color: #1a3a6b;
  }

  .moon-careers__quote span {
    font-size: 1.3rem;
    color: #777;
  }

  /* CTA */
  .moon-careers__cta {
    background: #111827;
    padding: 7rem 0;
    text-align: center;
  }

  .moon-careers__cta-inner {
    max-width: 72rem;
  }

  .moon-careers__cta .moon-careers__lead {
    margin-bottom: 2.4rem;
  }

  @media (max-width: 1024px) {
    .moon-careers__places,
    .moon-careers__jobs,
    .moon-careers__quotes,
    .moon-careers__culture-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px) {
    .moon-careers__section,
    .moon-careers__culture,
    .moon-careers__voices,
    .moon-careers__cta {
      padding: 4.5rem 0;
    }

    .moon-careers__hero {
      min-height: 48rem;
    }

    .moon-careers__place-body,
    .moon-careers__quote {
      padding: 2rem;
    }
  }
{% endstylesheet %}
