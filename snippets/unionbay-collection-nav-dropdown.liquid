{% doc %}
  Collection page category dropdown — parent Categories + Tops/Bottoms submenus.
  Uses women or men mega-menu links based on the current collection handle.

  @param {object} collection - Current collection
{% enddoc %}

{%- liquid
  assign handle = collection.handle | default: ''
  assign dept = 'women'
  if handle contains 'men-'
    unless handle contains 'women-'
      assign dept = 'men'
    endunless
  endif
  if handle == 'men-shop-all' or handle == 'mens-clothing-shop-all' or handle contains 'mens-'
    assign dept = 'men'
  endif
  if handle == 'women-shop-all' or handle == 'womens-clothing-shop-all'
    assign dept = 'women'
  endif
-%}

{%- if dept == 'men' -%}
  <div class="hollister-nav-dropdown">
    <div class="hollister-nav-dropdown__col">
      <p class="hollister-nav-dropdown__heading">Categories</p>
      <ul class="list-unstyled m-0 p-0">
        <li><a href="/collections/men-new-arrivals" class="hollister-nav-dropdown__link no-underline{% if handle == 'men-new-arrivals' %} is-active{% endif %}">New Arrivals</a></li>
        <li><a href="/collections/men-tops" class="hollister-nav-dropdown__link no-underline{% if handle == 'men-tops' %} is-active{% endif %}">Tops</a></li>
        <li><a href="/collections/men-bottoms" class="hollister-nav-dropdown__link no-underline{% if handle == 'men-bottoms' %} is-active{% endif %}">Bottoms</a></li>
        <li><a href="/collections/men-sweatshirts-sweatpants" class="hollister-nav-dropdown__link no-underline{% if handle == 'men-sweatshirts-sweatpants' %} is-active{% endif %}">Sweatshirts &amp; Sweatpants</a></li>
