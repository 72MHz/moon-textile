        <li><a href="/collections/men-t-shirts" class="hollister-nav-dropdown__link no-underline{% if handle == 'men-t-shirts' %} is-active{% endif %}">T-Shirts</a></li>
        <li><a href="/collections/men-graphic-tees" class="hollister-nav-dropdown__link no-underline{% if handle == 'men-graphic-tees' %} is-active{% endif %}">Graphic Tees</a></li>
        <li><a href="/collections/men-hoodies-sweatshirts" class="hollister-nav-dropdown__link no-underline{% if handle == 'men-hoodies-sweatshirts' %} is-active{% endif %}">Hoodies &amp; Sweatshirts</a></li>
        <li><a href="/collections/men-polos" class="hollister-nav-dropdown__link no-underline{% if handle == 'men-polos' %} is-active{% endif %}">Polos</a></li>
