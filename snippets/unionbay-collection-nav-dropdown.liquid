        <li><a href="/collections/men-clearance" class="hollister-nav-dropdown__link no-underline hollister-nav-dropdown__link--sale{% if handle == 'men-clearance' %} is-active{% endif %}">Clearance</a></li>
      </ul>
    </div>
    <div class="hollister-nav-dropdown__col">
