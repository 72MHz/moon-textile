      <ul class="unionbay-shop-all__nav-list list-unstyled">
        <li><a href="{{ base }}?ub_cat=thermal-waffle-ls-sweatshirt" class="unionbay-shop-all__nav-link no-underline{% if active == 'thermal-waffle-ls-sweatshirt' %} unionbay-shop-all__nav-link--active{% endif %}"{% if active == 'thermal-waffle-ls-sweatshirt' %} aria-current="page"{% endif %}>{{ 'unionbay.shop_all.thermal_waffle_ls_sweatshirt' | t }}</a></li>
