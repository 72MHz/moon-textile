      <ul class="unionbay-shop-all__nav-list list-unstyled">
        <li><a href="{{ base }}?ub_cat=bottoms" class="unionbay-shop-all__nav-link no-underline{% if active == 'bottoms' %} unionbay-shop-all__nav-link--active{% endif %}"{% if active == 'bottoms' %} aria-current="page"{% endif %}>{{ 'unionbay.shop_all.shop_all' | t }}</a></li>
