        <li><a href="{{ base }}?ub_cat=jackets" class="unionbay-shop-all__nav-link no-underline{% if active == 'jackets' %} unionbay-shop-all__nav-link--active{% endif %}"{% if active == 'jackets' %} aria-current="page"{% endif %}>{{ 'unionbay.shop_all.jackets' | t }}</a></li>
        <li><a href="{{ base }}?ub_cat=sweaters" class="unionbay-shop-all__nav-link no-underline{% if active == 'sweaters' %} unionbay-shop-all__nav-link--active{% endif %}"{% if active == 'sweaters' %} aria-current="page"{% endif %}>{{ 'unionbay.shop_all.sweaters' | t }}</a></li>
      </ul>
    </div>
    <div class="unionbay-shop-all__nav-group">
      <h3 class="unionbay-shop-all__nav-heading">{{ 'unionbay.shop_all.bottoms' | t }}</h3>
      <ul class="unionbay-shop-all__nav-list list-unstyled">
        <li><a href="{{ base }}?ub_cat=bottoms" class="unionbay-shop-all__nav-link no-underline{% if active == 'bottoms' %} unionbay-shop-all__nav-link--active{% endif %}"{% if active == 'bottoms' %} aria-current="page"{% endif %}>{{ 'unionbay.shop_all.shop_all' | t }}</a></li>
