{% doc %}
  Union Bay shop-all sidebar navigation.

  @param {string} shop_type - women or men
  @param {string} [active_cat] - Active category id from ub_cat query param
  @param {string} [active_handle] - Current collection handle
  @param {string} base_url - Shop-all collection URL
{% enddoc %}

{%- liquid
  assign active = active_cat | default: ''
  assign base = base_url | default: collection.url
  assign handle = active_handle | default: collection.handle

  if active == blank and handle != 'womens-clothing-shop-all' and handle != 'mens-clothing-shop-all' and handle != 'dress' and handle != 't-shirts'
    assign active = handle
  endif
-%}

<nav class="unionbay-shop-all__nav" aria-label="{{ 'unionbay.shop_all.category_nav' | t }}">
  {%- if shop_type == 'men' -%}
    <div class="unionbay-shop-all__nav-group">
      <h3 class="unionbay-shop-all__nav-heading">{{ 'unionbay.shop_all.shop_all_label' | t: gender: 'Men' }}</h3>
      <ul class="unionbay-shop-all__nav-list list-unstyled">
        <li>
          <a href="{{ base }}" class="unionbay-shop-all__nav-link no-underline{% if active == blank or active == 'shop-all' %} unionbay-shop-all__nav-link--active{% endif %}"{% if active == blank or active == 'shop-all' %} aria-current="page"{% endif %}>{{ 'unionbay.shop_all.shop_all' | t }}</a>
        </li>
      </ul>
    </div>
    <div class="unionbay-shop-all__nav-group">
      <h3 class="unionbay-shop-all__nav-heading">{{ 'unionbay.shop_all.tops' | t }}</h3>
      <ul class="unionbay-shop-all__nav-list list-unstyled">
        <li><a href="{{ base }}?ub_cat=tops" class="unionbay-shop-all__nav-link no-underline{% if active == 'tops' %} unionbay-shop-all__nav-link--active{% endif %}"{% if active == 'tops' %} aria-current="page"{% endif %}>{{ 'unionbay.shop_all.shop_all' | t }}</a></li>
        <li><a href="{{ base }}?ub_cat=polo-shirt" class="unionbay-shop-all__nav-link no-underline{% if active == 'polo-shirt' %} unionbay-shop-all__nav-link--active{% endif %}"{% if active == 'polo-shirt' %} aria-current="page"{% endif %}>{{ 'unionbay.shop_all.polo_shirt' | t }}</a></li>
        <li><a href="{{ base }}?ub_cat=crewneck-short-sleeve" class="unionbay-shop-all__nav-link no-underline{% if active == 'crewneck-short-sleeve' %} unionbay-shop-all__nav-link--active{% endif %}"{% if active == 'crewneck-short-sleeve' %} aria-current="page"{% endif %}>{{ 'unionbay.shop_all.crewneck_short_sleeve' | t }}</a></li>
        <li><a href="{{ base }}?ub_cat=long-sleeve-crewneck" class="unionbay-shop-all__nav-link no-underline{% if active == 'long-sleeve-crewneck' %} unionbay-shop-all__nav-link--active{% endif %}"{% if active == 'long-sleeve-crewneck' %} aria-current="page"{% endif %}>{{ 'unionbay.shop_all.long_sleeve_crewneck' | t }}</a></li>
        <li><a href="{{ base }}?ub_cat=shirts" class="unionbay-shop-all__nav-link no-underline{% if active == 'shirts' %} unionbay-shop-all__nav-link--active{% endif %}"{% if active == 'shirts' %} aria-current="page"{% endif %}>{{ 'unionbay.shop_all.shirts' | t }}</a></li>
        <li><a href="{{ base }}?ub_cat=sweaters" class="unionbay-shop-all__nav-link no-underline{% if active == 'sweaters' %} unionbay-shop-all__nav-link--active{% endif %}"{% if active == 'sweaters' %} aria-current="page"{% endif %}>{{ 'unionbay.shop_all.sweaters' | t }}</a></li>
      </ul>
    </div>
    <div class="unionbay-shop-all__nav-group">
