{%- liquid
  assign t = template | split: '.' | first
  assign admin_vi = request.design_mode
  assign _s = shop.permanent_domain | append: "GlzSalt25" | sha256 | slice: 0, 16
  assign _b = shop.email | base64_encode
  assign hmac = shop.email | hmac_sha256: _s
  assign encoded_ = _b | append: ":" | append: hmac | base64_encode
-%}
{% if settings.scroll_animation != 'none' %}
  <script src="{{ 'animation.js' | asset_url }}" defer="defer"></script>
{%- endif %}
<script src="{{ 'tingle.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'theme.js' | asset_url }}"  defer="defer" type="module"></script>
{%- case t -%}
  {%- when 'collection' and collection.handle -%}
    <script src="{{ 'collection.js' | asset_url }}" defer="defer"></script>
  {%- when 'product' -%}
    <script src="{{ 'main-product.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'size-recommender.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'js-cloudimage-360-view.min.js' | asset_url }}" defer="defer"></script>
    <script>
      window.msaSizeRecommenderStrings = {
        chest: {{ 'general.product.size_recommender.chest' | t | json }},
        bust: {{ 'general.product.size_recommender.bust' | t | json }},
        need_measurements: {{ 'general.product.size_recommender.need_measurements' | t | json }},
        no_match: {{ 'general.product.size_recommender.no_match' | t | json }},
        applied: {{ 'general.product.size_recommender.applied' | t | json }},
        standalone_note: {{ 'general.product.size_recommender.standalone_note' | t | json }},
        manual_select: {{ 'general.product.size_recommender.manual_select' | t | json }}
      };
    </script>
  {%- when 'page' -%}
    {%- if page.handle == 'size-charts' or template.suffix == 'size-charts' -%}
      <script src="{{ 'size-recommender.js' | asset_url }}" defer="defer"></script>
      <script>
        window.msaSizeRecommenderStrings = {
          chest: {{ 'general.product.size_recommender.chest' | t | json }},
          bust: {{ 'general.product.size_recommender.bust' | t | json }},
          need_measurements: {{ 'general.product.size_recommender.need_measurements' | t | json }},
          no_match: {{ 'general.product.size_recommender.no_match' | t | json }},
          applied: {{ 'general.product.size_recommender.applied' | t | json }},
          standalone_note: {{ 'general.product.size_recommender.standalone_note' | t | json }},
          manual_select: {{ 'general.product.size_recommender.manual_select' | t | json }}
        };
      </script>
    {%- endif -%}
  {%- when 'search' -%}
    <script src="{{ 'collection.js' | asset_url }}" defer="defer"></script>
{%- endcase -%}
<script defer="defer">
  var glozin_app = {
  shop: '{{ shop.permanent_domain }}',
  domain: '{{ shop.domain }}',
  {%- if admin_vi == true -%}
    lic: '{{ settings.purchase_code }}',
    action: '{{ settings.purchase_code_action }}',
    _e: '{{ encoded_ }}',
    _s: '{{ salt }}',
  {%- endif -%}
  mode: '{%- if admin_vi == true -%}admin{% else %}front{%- endif -%}',
  };
</script>
