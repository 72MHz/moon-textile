{% doc %}
  Minimal Union Bay style social icons without circular backgrounds.

  Uses theme social settings from config/settings_schema.json.
{% enddoc %}

{%- liquid
  assign has_social = false
  if settings.facebook != blank or settings.instagram != blank or settings.twitter != blank
    assign has_social = true
  endif
-%}

{%- if has_social -%}
  <ul class="unionbay-footer-social list-unstyled">
    {%- if settings.instagram != blank -%}
      <li>
        <a href="{{ settings.instagram }}" target="_blank" rel="noopener" aria-label="{{ 'general.social.links.instagram' | t }}">
          <svg width="18" height="16" viewBox="0 0 18 16" fill="none" aria-hidden="true">
            <path d="M13.2565 0H4.74353C2.13353 0 0 1.93882 0 4.30588V11.6894C0 14.0565 2.13353 15.9953 4.74353 15.9953H13.2565C15.8665 15.9953 18 14.0565 18 11.6894V4.30588C18 1.93882 15.8665 0 13.2565 0ZM16.3906 11.5859C16.3906 13.2282 14.9135 14.5694 13.1082 14.5694H4.90235C3.09706 14.5694 1.62 13.2282 1.62 11.5859V4.41412C1.62 2.77176 3.09706 1.43059 4.90235 1.43059H13.1082C14.9135 1.43059 16.3906 2.77176 16.3906 4.41412V11.5859Z" fill="currentColor"/>
            <path d="M8.99913 3.89176C6.5003 3.89176 4.47266 5.73176 4.47266 8C4.47266 10.2682 6.5003 12.1082 8.99913 12.1082C11.498 12.1082 13.5256 10.2682 13.5256 8C13.5256 5.73176 11.498 3.89176 8.99913 3.89176ZM8.99913 10.6494C7.38442 10.6494 6.08207 9.46353 6.08207 8C6.08207 6.53647 7.38972 5.35059 9.00442 5.35059C10.6191 5.35059 11.9215 6.53647 11.9215 8C11.9215 9.46353 10.6138 10.6494 8.99913 10.6494Z" fill="currentColor"/>
            <path d="M13.7698 4.59765C14.3341 4.59765 14.7916 4.18259 14.7916 3.67059C14.7916 3.15859 14.3341 2.74353 13.7698 2.74353C13.2055 2.74353 12.748 3.15859 12.748 3.67059C12.748 4.18259 13.2055 4.59765 13.7698 4.59765Z" fill="currentColor"/>
          </svg>
        </a>
      </li>
    {%- endif -%}
    {%- if settings.facebook != blank -%}
      <li>
        <a href="{{ settings.facebook }}" target="_blank" rel="noopener" aria-label="{{ 'general.social.links.facebook' | t }}">
          <svg width="9" height="16" viewBox="0 0 9 16" fill="none" aria-hidden="true">
            <path d="M8.35753 8.53513H0V5.33334H9L8.35753 8.53513Z" fill="currentColor"/>
            <path d="M1.94944 3.22418V16.0045H5.78807V3.73468C5.78807 3.38539 6.03103 3.20179 6.43055 3.20179H9.00043V0H6.03643C1.84686 0 1.94944 2.80325 1.94944 3.22418Z" fill="currentColor"/>
          </svg>
        </a>
      </li>
    {%- endif -%}
    {%- if settings.twitter != blank -%}
      <li>
        <a href="{{ settings.twitter }}" target="_blank" rel="noopener" aria-label="{{ 'general.social.links.twitter' | t }}">
          <svg width="17" height="16" viewBox="0 0 17 16" fill="none" aria-hidden="true">
            <path d="M12.6 1.5h2.2l-4.8 5.5L16 14.5h-4.4L9.2 10.2 4.5 14.5H2.3l5.1-5.9L2 1.5h4.5l3.4 4.5L12.6 1.5zm-.8 11.7h1.2L5.4 2.8H4.1l7.7 10.4z" fill="currentColor"/>
          </svg>
        </a>
      </li>
    {%- endif -%}
  </ul>
{%- endif -%}
