{% doc %}
  Renders the Union Bay hero banner with split winter lifestyle imagery.

  @param {string} heading - Hero heading for alt text
  @param {string} [class] - CSS class for the img elements
{% enddoc %}

<div class="unionbay-hero__split absolute inset-0 w-full h-full">
  <div class="unionbay-hero__split-panel unionbay-hero__split-panel--women">
    <img
      src="{{ 'ub-hero-winter-women.jpg' | asset_url }}"
      alt="{{ heading | escape }} — women's winter styles"
      class="{{ class | default: 'unionbay-hero__asset' }}"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      width="1400"
      height="1200"
    >
  </div>
  <div class="unionbay-hero__split-panel unionbay-hero__split-panel--men">
    <img
      src="{{ 'ub-hero-winter-men.jpg' | asset_url }}"
      alt="{{ heading | escape }} — men's winter styles"
      class="{{ class | default: 'unionbay-hero__asset' }}"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      width="1400"
      height="1200"
    >
  </div>
  <img
    src="{{ 'ub-hero-winter-mobile.jpg' | asset_url }}"
    alt="{{ heading | escape }}"
    class="unionbay-hero__asset unionbay-hero__asset--mobile"
    loading="eager"
    fetchpriority="high"
    decoding="async"
    width="800"
    height="1000"
  >
</div>
